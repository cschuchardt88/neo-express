{
  "name": "neo-express-toolkit",
  "displayName": "Neo Express Toolkit",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "neo-express-toolkit.helloWorld",
        "title": "Hello World"
      }
    ],
    "views": {
      "neo-express-explorer": [
        {
          "id": "neo-express-toolkit.views.wallet",
          "name": "Wallets"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "neo-express-explorer",
          "title": "Neo Express Explorer",
          "icon": "resources/neo-express.png"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "install:all": "npm install && cd webview-ui && npm install",
    "dev:webview": "cd webview-ui && npm run dev",
    "build:webview": "cd webview-ui && npm run build",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.3",
    "@types/node": "18.x",
    "@types/vscode": "^1.84.0",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "@vscode/test-electron": "^2.3.6",
    "eslint": "^8.52.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.2.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "uuid": "^9.0.1",
    "ws": "^8.14.2"
  }
}
